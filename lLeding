<form id="consult-google-form" class="space-y-4">
    <input type="hidden" id="c-date" value="05.07.2026">
    
    <div>
        <label class="block text-sm font-medium">Ім'я або Прізвище</label>
        <input type="text" id="c-name" required class="w-full border p-2 rounded">
    </div>
    <div>
        <label class="block text-sm font-medium">Email</label>
        <input type="email" id="c-email" required class="w-full border p-2 rounded">
    </div>
    <div>
        <label class="block text-sm font-medium">Телефон</label>
        <input type="tel" id="c-phone" required class="w-full border p-2 rounded">
    </div>
    <div>
        <label class="block text-sm font-medium">Кількість дітей</label>
        <input type="number" id="c-kids-total" min="0" class="w-full border p-2 rounded">
    </div>
    <div>
        <label class="block text-sm font-medium">Дівчата (вік)</label>
        <input type="text" id="c-girls" placeholder="наприклад: 5, 8" class="w-full border p-2 rounded">
    </div>
    <div>
        <label class="block text-sm font-medium">Хлопці (вік)</label>
        <input type="text" id="c-boys" placeholder="наприклад: 3, 10" class="w-full border p-2 rounded">
    </div>
    
    <button type="submit" id="consult-submit-btn" class="w-full bg-blue-800 text-white py-2 rounded">Зареєструватися</button>
</form>
<script>
    // Здесь разместите код, который вы прислали
    document.getElementById('consult-google-form').addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = document.getElementById('consult-submit-btn');
        btn.disabled = true;
        btn.innerText = "Обробка...";

        // ЗАМЕНИТЕ ЭТУ ССЫЛКУ на ваш реальный URL из Make или Google Apps Script
        var scriptURL = 'ВАШ_URL_З_MAKE_АБО_GAS'; 
        
        var urlParams = new URLSearchParams();
        urlParams.append('date', document.getElementById('c-date').value);
        urlParams.append('name', document.getElementById('c-name').value);
        urlParams.append('email', document.getElementById('c-email').value);
        urlParams.append('phone', document.getElementById('c-phone').value);
        urlParams.append('total_kids', document.getElementById('c-kids-total').value);
        urlParams.append('girls', document.getElementById('c-girls').value);
        urlParams.append('boys', document.getElementById('c-boys').value);

        fetch(scriptURL, { method: 'POST', mode: 'no-cors', body: urlParams })
        .then(function() {
            alert("Дякуємо! Ваша реєстрація прийнята.");
            document.getElementById('consult-google-form').reset();
        })
        .catch(function() {
            alert("Помилка відправки.");
        })
        .finally(function() {
            btn.disabled = false;
            btn.innerText = "Зареєструватися";
        });
    });
</script>
</body>
